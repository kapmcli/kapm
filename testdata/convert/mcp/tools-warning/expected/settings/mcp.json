{
  "mcpServers": {
    "http-server": {
      "url": "https://example.com/mcp",
      "headers": {
        "Authorization": "Bearer ${TOKEN}"
      }
    },
    "stdio-server": {
      "command": "python",
      "args": [
        "-m",
        "my_server"
      ],
      "env": {
        "API_KEY": "${MY_KEY}"
      }
    }
  }
}
